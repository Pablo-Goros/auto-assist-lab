# Shared local development values (non-sensitive placeholders)

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Backend
DATABASE_URL=postgresql+psycopg://autoassist:autoassist@localhost:5433/autoassist
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-adminsdk.json
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC_ID=service-request-events
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# Seed data (replace firebase UIDs with real values from Firebase Auth)
SEED_OWNER_FIREBASE_UID=your-owner-firebase-uid
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_NAME=Test Owner
SEED_OPERATOR_FIREBASE_UID=your-operator-firebase-uid
SEED_OPERATOR_EMAIL=operator@example.com
SEED_OPERATOR_NAME=Test Operator
TEST_DATABASE_URL=postgresql+psycopg://autoassist:autoassist@localhost:5433/autoassist_test

# Worker
PUBSUB_SUBSCRIPTION_ID=notification-worker-subscription
