{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check:api": "npm run generate:api && git diff --exit-code -- ../openapi.json src/api/generated.ts",
    "generate:api": "python ../backend/scripts/export_openapi.py && openapi-typescript ../openapi.json -o src/api/generated.ts",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "type-check": "tsc -b --noEmit"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.10.1",
    "oxlint": "^1.71.0",
    "typescript": "~5.9.3",
    "vite": "^8.1.1",
    "vitest": "^3.2.4"
  }
}
